# ── Frontend (Vite) ──────────────────────────────────────────
# Project Settings → API en el dashboard de Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── Edge Functions (secretos de Supabase) ────────────────────
# Configura estos en: Supabase Dashboard → Edge Functions → Secrets
# O con: supabase secrets set KEY=value
#
# STRIPE_SECRET_KEY=sk_live_...          # Clave secreta de Stripe (NUNCA al front)
# STRIPE_WEBHOOK_SECRET=whsec_...        # Signing secret del webhook en Stripe Dashboard
# STRIPE_PRICE_PRO=price_...             # Price ID del plan Pro ($299 MXN/mes, recurrente)
# STRIPE_PRICE_PREMIUM=price_...         # Price ID del plan Premium ($599 MXN/mes, recurrente)
# APP_URL=https://coachpro-gray.vercel.app  # URL de la app (success/cancel redirect)
# ENVIRONMENT=production                 # Bloquea set-plan-manual en prod
#
# Las vars SUPABASE_URL y SUPABASE_SERVICE_ROLE_KEY las inyecta
# Supabase automáticamente en todas las Edge Functions.

# ── Stripe Dashboard — pasos para crear Products/Prices ─────
# 1. Stripe Dashboard → Products → + Add product
#    - Nombre: "CoachPro Pro"  | Precio: $299 MXN | Recurrente mensual
#    - Copiar el Price ID (price_xxx) → STRIPE_PRICE_PRO
# 2. Repetir para "CoachPro Premium" $599 MXN → STRIPE_PRICE_PREMIUM
# 3. Stripe Dashboard → Webhooks → + Add endpoint
#    - URL: https://YOUR_PROJECT.supabase.co/functions/v1/stripe-webhook
#    - Eventos a escuchar:
#        checkout.session.completed
#        customer.subscription.updated
#        customer.subscription.deleted
#        invoice.paid
#        invoice.payment_failed
#    - Copiar Signing secret → STRIPE_WEBHOOK_SECRET

# ── Tarjetas de prueba (Stripe test mode) ───────────────────
# 4242 4242 4242 4242  → Pago exitoso
# 4000 0000 0000 9995  → Pago rechazado (fondos insuficientes)
# 4000 0025 0000 3155  → Requiere autenticación 3D Secure
# Usa cualquier fecha futura y cualquier CVV de 3 dígitos.
#
# Flujo de prueba completo:
# 1. Inicia sesión como coach en trial
# 2. Planes → "Suscribirse a Pro" → Stripe Checkout (tarjeta 4242...)
# 3. Completa el pago → regresa con ?checkout=success
# 4. Espera ~5s al webhook → refresca, el plan debe ser "Pro"
# 5. Gestionar suscripción → Customer Portal → Cancelar
# 6. Webhook subscription.deleted → plan cae a read_only
# 7. Para simular en dev sin Stripe: supabase functions invoke set-plan-manual --body '{"plan":"pro"}'
